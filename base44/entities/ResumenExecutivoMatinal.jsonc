{
  "name": "ResumenExecutivoMatinal",
  "type": "object",
  "properties": {
    "atendente_id": {
      "type": "string",
      "description": "ID do User (atendente)"
    },
    "atendente_nome": {
      "type": "string",
      "description": "Nome completo do atendente"
    },
    "email_atendente": {
      "type": "string",
      "format": "email",
      "description": "Email para envio opcional"
    },
    "data_geracao": {
      "type": "string",
      "format": "datetime",
      "description": "Data/hora de gera\u00e7\u00e3o do resumo"
    },
    "metas_dia": {
      "type": "string",
      "description": "Tarefas cr\u00edticas e metas do dia"
    },
    "clientes_prioritarios": {
      "type": "string",
      "description": "Top 3 clientes para focar (nome + score)"
    },
    "alertas_24h": {
      "type": "string",
      "description": "JSON com contadores: total_threads_ativos, threads_sem_resposta, threads_urgentes"
    },
    "resumo_ia": {
      "type": "string",
      "description": "Resumo executivo gerado via Anthropic (Foco, Clientes, Aten\u00e7\u00e3o, Dica)"
    },
    "enviado_whatsapp": {
      "type": "boolean",
      "default": false,
      "description": "Se foi enviado via WhatsApp"
    },
    "exibido_dashboard": {
      "type": "boolean",
      "default": true,
      "description": "Se deve ser exibido no Dashboard"
    },
    "data_leitura": {
      "type": "string",
      "format": "datetime",
      "description": "Quando o atendente leu o resumo"
    },
    "feedback_atendente": {
      "type": "string",
      "description": "Feedback do atendente sobre o resumo"
    }
  },
  "required": [
    "atendente_id",
    "atendente_nome",
    "data_geracao",
    "resumo_ia"
  ]
}