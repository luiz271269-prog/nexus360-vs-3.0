{
  "name": "ListaVendedor",
  "type": "object",
  "description": "Listas de trabalho de clientes/contatos por vendedor (ex: Top 30, Estrat\u00e9gicos, Reativa\u00e7\u00e3o)",
  "properties": {
    "nome": {
      "type": "string",
      "description": "Nome da lista (ex: Lista 1 - Top 30)"
    },
    "descricao": {
      "type": "string",
      "description": "Descri\u00e7\u00e3o/objetivo da lista"
    },
    "vendedor_id": {
      "type": "string",
      "description": "User.id do vendedor dono da lista"
    },
    "vendedor_nome": {
      "type": "string",
      "description": "Nome do vendedor (cache para exibi\u00e7\u00e3o)"
    },
    "cliente_ids": {
      "type": "array",
      "items": {
        "type": "string"
      },
      "default": [],
      "description": "IDs dos Clientes que fazem parte da lista"
    },
    "contato_ids": {
      "type": "array",
      "items": {
        "type": "string"
      },
      "default": [],
      "description": "IDs dos Contacts (contatos avulsos) que fazem parte da lista"
    },
    "itens_importados": {
      "type": "array",
      "items": {
        "type": "object",
        "properties": {
          "nome": {
            "type": "string"
          },
          "cnpj": {
            "type": "string"
          },
          "telefone": {
            "type": "string"
          },
          "cidade": {
            "type": "string"
          },
          "observacao": {
            "type": "string"
          }
        }
      },
      "default": [],
      "description": "Itens importados de arquivo que n\u00e3o foram vinculados a nenhum cliente/contato existente (mantidos na lista para trabalho)"
    },
    "cor": {
      "type": "string",
      "enum": [
        "blue",
        "green",
        "purple",
        "orange",
        "pink",
        "teal",
        "red",
        "amber"
      ],
      "default": "blue",
      "description": "Cor do badge da lista"
    },
    "ordem": {
      "type": "number",
      "default": 10,
      "description": "Ordem de exibi\u00e7\u00e3o (menor primeiro)"
    },
    "ativa": {
      "type": "boolean",
      "default": true
    }
  },
  "required": [
    "nome",
    "vendedor_id"
  ],
  "rls": {
    "create": {},
    "read": {
      "$or": [
        {
          "data.vendedor_id": "{{user.id}}"
        },
        {
          "created_by_id": "{{user.id}}"
        },
        {
          "user_condition": {
            "role": "admin"
          }
        }
      ]
    },
    "update": {
      "$or": [
        {
          "data.vendedor_id": "{{user.id}}"
        },
        {
          "created_by_id": "{{user.id}}"
        },
        {
          "user_condition": {
            "role": "admin"
          }
        }
      ]
    },
    "delete": {
      "$or": [
        {
          "data.vendedor_id": "{{user.id}}"
        },
        {
          "user_condition": {
            "role": "admin"
          }
        }
      ]
    }
  }
}